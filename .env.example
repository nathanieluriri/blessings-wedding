# ── Environment template ───────────────────────────────────────
# Copy to .env.local and fill in real values. Do NOT commit .env.local.

# MongoDB connection (local dev: a running mongod on port 27017)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=blessings_wedding

# Secret used to sign admin session JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# Root admin credentials — auto-seeded on first boot when no admins exist.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Public site URL (metadata / Open Graph, and to build links inside emails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Resend (transactional email) ───────────────────────────────
# Create a key at https://resend.com/api-keys (Sending Access is enough).
RESEND_API_KEY=
# Sender address. Use a verified-domain address to email anyone; falls back to
# Resend's test sender (onboarding@resend.dev → only your own account email).
RESEND_FROM="Blessings & Justice <onboarding@resend.dev>"
